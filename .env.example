# Slack app credentials (from api.slack.com/apps after creating app from manifest.json)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...   # App-level token with connections:write (Socket Mode)
SLACK_SIGNING_SECRET=...

# LLM — any OpenAI-compatible endpoint. Default: Google Gemini FREE tier.
# Get a free key (no credit card): https://aistudio.google.com/apikey
LLM_API_KEY=AIza...
# Defaults (Gemini) are set in code; uncomment below to switch to Groq's free tier instead:
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL_FAST=llama-3.1-8b-instant
# LLM_MODEL_SMART=llama-3.3-70b-versatile

# Rally settings
RALLY_DB_PATH=rally.db
RALLY_SIMULATION=1          # 1 = simulated volunteers auto-respond (demo/judge mode)
RALLY_COORDINATOR_IDS=      # comma-separated Slack user IDs treated as coordinators (empty = everyone)
